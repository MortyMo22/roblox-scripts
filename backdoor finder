-- Список подозрительных Remote
local suspiciousRemotes = {}

-- Список опасных ключевых слов
local dangerousPatterns = {
    "loadstring",
    "require",
    "getfenv",
    "setfenv",
    "HttpGet",
    "RunString",
    "Execute",
    "Admin",
    "Command",
    "Owner"
}

-- Проверка ModuleScript / Script
local function analyzeScript(scr)
    local src
    pcall(function()
        src = scr.Source
    end)
    if not src then return end

    for _, pattern in ipairs(dangerousPatterns) do
        if src:lower():find(pattern:lower()) then
            log("⚠ Подозрительный Script: " .. scr:GetFullName(), Color3.fromRGB(180, 0, 0))
            return
        end
    end
end

-- Проверка RemoteEvent/RemoteFunction
local function analyzeRemote(remote)
    local name = remote.Name:lower()

    -- Подозрительные имена
    for _, pattern in ipairs(dangerousPatterns) do
        if name:find(pattern:lower()) then
            log("⚠ Подозрительное имя Remote: " .. remote:GetFullName(), Color3.fromRGB(255, 120, 0))
        end
    end

    -- Проверка на открытый RemoteEvent
    if remote:IsA("RemoteEvent") then
        local success, err = pcall(function()
            remote:FireServer({})
        end)

        if success then
            log("🔥 Открытый RemoteEvent (принимает любые данные): " .. remote:GetFullName(), Color3.fromRGB(255, 0, 0))
        end
    end

    -- Проверка RemoteFunction
    if remote:IsA("RemoteFunction") then
        local success, result = pcall(function()
            return remote:InvokeServer({})
        end)

        if success then
            log("⚠ RemoteFunction возвращает данные: " .. remote:GetFullName(), Color3.fromRGB(255, 150, 0))
        end
    end
end

-- Основной анализ
for _, obj in ipairs(game:GetDescendants()) do
    if obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("ModuleScript") then
        analyzeScript(obj)
    end

    if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
        analyzeRemote(obj)
    end
end

log("✔ Анализ завершён", Color3.fromRGB(0, 170, 0))
